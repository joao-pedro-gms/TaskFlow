# Copy this file to .env and adjust values before running docker-compose
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret

# MongoDB
MONGO_USER=taskflow
MONGO_PASSWORD=taskflow_secret

# ActiveMQ
ACTIVEMQ_USER=admin
ACTIVEMQ_PASSWORD=admin_secret

# JWT — CHANGE THIS in production! Must be at least 256 bits (32 chars).
JWT_SECRET=change_this_in_production_must_be_at_least_256_bits_long_secret_key
